DOCUMENTS_DIR=../../data/documents
CHUNK_STRATEGY=markdown_heading
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
