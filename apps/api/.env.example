SILICONFLOW_API_KEY=your_siliconflow_key

LLM_PROVIDER=siliconflow
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=Pro/BAAI/bge-m3

VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=../../data/vector_store/chroma
COLLECTION_NAME=after_sales_knowledge

DOCUMENTS_DIR=../../data/documents
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# RAG 消融实验开关
RAG_ENABLE_MQE=true
RAG_ENABLE_BM25=true
RAG_ENABLE_RRF=true
RAG_ENABLE_RERANK=true
RAG_ENABLE_ADJACENT_CONTEXT=true
RAG_ENABLE_ROUTER=true
RAG_ROUTER_MODE=rule
RAG_ROUTER_CONFIDENCE_THRESHOLD=0.65

# Agent 顶层路由：rule 只用规则；llm 全部交给大模型；hybrid 只在模糊/高风险问题上调用大模型复核
AGENT_ROUTER_MODE=hybrid
AGENT_ROUTER_CONFIDENCE_THRESHOLD=0.88
AGENT_ENABLE_ANSWER_GUARD=true

# LangSmith 可观测性（按需开启）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls__your_langsmith_key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=copilot
